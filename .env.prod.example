# Werewolf — production env file for `docker compose up`.
#
# Copy to .env.prod and fill in real values. The compose stack and the Spring
# Boot backend both read this file. Anything unset that the backend requires
# will cause it to fail-fast at startup.

# --- Image version --------------------------------------------------------
# The ghcr.io image tag prod should run. Set to a specific release tag
# (e.g. v0.2.0) to pin, or `latest` to always track the newest published
# release. Must match a tag that the `Publish Images` workflow has pushed
# to ghcr.io/wangdaqian08/werewolf-simple-{backend,frontend}.
#
# To deploy a new version:
#   1. Update this value (e.g. v0.2.0 → v0.3.0).
#   2. ssh prod vm && cd /opt/werewolf-simple
#   3. docker compose --env-file .env.prod pull
#   4. docker compose --env-file .env.prod up -d
WEREWOLF_VERSION=latest

# --- Spring profile -------------------------------------------------------
# Must be `prod` for production deployments.
SPRING_PROFILES_ACTIVE=prod

# --- Postgres -------------------------------------------------------------
# POSTGRES_DB / POSTGRES_USER / POSTGRES_PASSWORD are read by BOTH the
# postgres container (initialises the db on first boot) and the backend
# container (connects to it). DB_HOST defaults to the `postgres` compose
# service name; only override for an external database.
POSTGRES_DB=werewolf
POSTGRES_USER=werewolf
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
# DB_HOST / DB_PORT are set by docker-compose.yml to postgres:5432; uncomment
# to override (e.g. pointing at a managed Postgres outside the compose stack).
# DB_HOST=postgres
# DB_PORT=5432

# --- JWT signing secret (REQUIRED, min 32 chars for HS256) ---------------
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_at_least_32_characters_long_random_string

# --- Google OAuth (REQUIRED — auto-config reads these at startup) --------
# If you don't plan to use Google login, set both to any non-empty
# placeholder (e.g. "disabled") so Spring's OAuth2 auto-config still boots.
GOOGLE_CLIENT_ID=CHANGE_ME_or_set_to_disabled
GOOGLE_CLIENT_SECRET=CHANGE_ME_or_set_to_disabled
# Must match the redirect URI registered in Google Cloud Console.
GOOGLE_REDIRECT_URI=https://your-domain.example.com/auth/callback/google

# --- WeChat OAuth (OPTIONAL — leave blank if unused) ---------------------
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# --- Frontend origin (REQUIRED) ------------------------------------------
# Exact scheme+host of the Vue app. Drives BOTH:
#   - CORS allowlist (app.cors.allowed-origins)
#   - WebSocket origin validation (websocket.allowed-origins)
# Single origin:
#   FRONTEND_ORIGIN=https://werewolf.example.com
# Multiple origins (comma-separated, no spaces):
#   FRONTEND_ORIGIN=https://werewolf.example.com,https://staging.werewolf.example.com
# Mobile Safari blocks ws://, so this MUST be https:// in real production.
FRONTEND_ORIGIN=https://your-domain.example.com

# --- Server port (optional, defaults to 8080) ----------------------------
SERVER_PORT=8080

# --- Log file path -------------------------------------------------------
# Inside the backend container; logs also go to stdout via journalctl/logs.
LOG_FILE=/var/log/werewolf/backend.log
