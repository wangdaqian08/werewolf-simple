# Copy this file to .env.prod (or /etc/werewolf/env) and fill in real values.
# Every variable without a default in application-prod.yml MUST be set,
# otherwise Spring Boot will fail to start.

# Active Spring profile — must be 'prod' for production deployments.
SPRING_PROFILES_ACTIVE=prod

# --- Database (Docker-based Postgres on 127.0.0.1:5432) ------------------
# DB_HOST defaults to 127.0.0.1, DB_PORT defaults to 5432. Override only
# if your Postgres instance binds elsewhere.
DB_HOST=127.0.0.1
DB_PORT=5432
POSTGRES_DB=werewolf
POSTGRES_USER=werewolf
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# --- JWT signing secret (REQUIRED, min 32 chars for HS256) ---------------
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_at_least_32_characters_long_random_string

# --- Google OAuth (REQUIRED — auto-config reads these at startup) --------
# If you don't plan to use Google login, set both to any non-empty
# placeholder (e.g. "disabled") so Spring's OAuth2 auto-config still boots.
# AuthController will simply fail at runtime if a /api/auth/google call
# arrives with unconfigured creds — it won't affect other endpoints.
GOOGLE_CLIENT_ID=CHANGE_ME_or_set_to_disabled
GOOGLE_CLIENT_SECRET=CHANGE_ME_or_set_to_disabled
# Must match the redirect URI registered in Google Cloud Console.
GOOGLE_REDIRECT_URI=https://your-domain.example.com/auth/callback/google

# --- WeChat OAuth (OPTIONAL — leave blank if unused) ---------------------
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# --- Frontend origin (REQUIRED) ------------------------------------------
# Exact scheme+host of the Vue app, used as the CORS/WebSocket allowlist.
# Mobile Safari blocks ws://, so this must be https:// in production.
FRONTEND_ORIGIN=https://your-domain.example.com

# --- Server port (optional, defaults to 8080) ----------------------------
SERVER_PORT=8080

# --- Log file path (optional, defaults to /var/log/werewolf/backend.log) -
# Directory must exist and be writable by the service user.
LOG_FILE=/var/log/werewolf/backend.log
